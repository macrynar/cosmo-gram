{
  "crons": [
    {
      "path": "/api/cron/daily-horoscope",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-personal-horoscope",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-chat-sessions",
      "schedule": "0 3 1 * *"
    }
  ],
  "redirects": [
    { "source": "/generate",           "destination": "/app/cosmogram",        "permanent": true },
    { "source": "/astro-match",        "destination": "/app/match",            "permanent": true },
    { "source": "/astro-match/:path*", "destination": "/app/match/:path*",     "permanent": true },
    { "source": "/chat",               "destination": "/app/chat",             "permanent": true },
    { "source": "/children",           "destination": "/app/library",          "permanent": true },
    { "source": "/child/:id",          "destination": "/app/library/:id",      "permanent": true },
    { "source": "/settings",           "destination": "/app/settings/profile", "permanent": true },
    { "source": "/profile",            "destination": "/app/settings/profile", "permanent": true },
    { "source": "/dashboard",          "destination": "/app/today",            "permanent": true },
    { "source": "/natal",              "destination": "/app/cosmogram",        "permanent": true },
    { "source": "/horoskop-dzienny",   "destination": "/daily-horoscope",      "permanent": true }
  ]
}
